# Authentication
JWT_SECRET=replace_with_min_32_chars_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
ADMIN_JWT_EXPIRE_HOURS=24

# Gemini
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
VOICE_NAME=Kore
VOICE_TEMPERATURE=0.55
VOICE_MAX_OUTPUT_TOKENS=1400
VOICE_SYSTEM_PROMPT_MAX_CHARS=12000

# Google Cloud
GOOGLE_CLOUD_PROJECT=museai-2026
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GCS_BUCKET=museai-assets

# CORS
ALLOWED_ORIGINS=http://localhost:3000
APP_ENV=development
# Legacy fallback read by code in some places
ENV=development
ENFORCE_HTTPS=false

# Redis / Rate limiting
REDIS_URL=redis://localhost:6379
WS_MAX_PER_IP=3
WS_MAX_PER_HOUR=20
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# WebSocket security
WS_REQUIRE_EPHEMERAL_TOKEN=true
EPHEMERAL_TOKEN_EXPIRE_SECONDS=3600
