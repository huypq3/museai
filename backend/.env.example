# =======================================
# MuseAI Backend — Environment Variables
# =======================================
# Copy this file to .env and fill real values.
# Never commit .env or service-account credentials to Git.

# --- Runtime ---------------------------------------------------------------
APP_ENV=development
# development | production
ENV=development
HOST=0.0.0.0
PORT=8080
ENFORCE_HTTPS=false

# --- Security / Auth -------------------------------------------------------
JWT_SECRET=replace_with_min_32_chars_random_secret
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_JWT_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256
ADMIN_AUTH_COOKIE_NAME=museai_admin_session
ADMIN_AUTH_COOKIE_SECURE=false
ADMIN_AUTH_COOKIE_SAMESITE=none
ADMIN_AUTH_COOKIE_PATH=/
ADMIN_AUTH_COOKIE_MAX_AGE=86400

# Bootstrap super-admin account (first run only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
# Prefer bcrypt hash (higher priority than ADMIN_PASSWORD)
# Generate: python3 -c "import bcrypt; print(bcrypt.hashpw(b'Museai2026A1', bcrypt.gensalt(12)).decode())"

# --- Gemini Live / Voice ---------------------------------------------------
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
VOICE_NAME=Kore
VOICE_TEMPERATURE=0.55
VOICE_MAX_OUTPUT_TOKENS=1400
VOICE_SYSTEM_PROMPT_MAX_CHARS=12000

# --- Google Cloud ----------------------------------------------------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIRESTORE_DATABASE=(default)

# Cloud Storage
GCS_BUCKET=your-gcs-bucket-name
GCS_BUCKET_NAME=your-gcs-bucket-name

# --- CORS ------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
# Production example:
# ALLOWED_ORIGINS=https://guideqr.ai,https://www.guideqr.ai

# --- Public App URL (QR generation fallback) -------------------------------
# admin_qr.py uses museum.qr_base_url first, then these env vars in order:
# PUBLIC_APP_URL -> FRONTEND_PUBLIC_URL -> APP_PUBLIC_URL -> http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
FRONTEND_PUBLIC_URL=
APP_PUBLIC_URL=

# --- Redis / Rate Limiting -------------------------------------------------
REDIS_URL=
# Empty => in-memory fallback (dev only)
# Production example: redis://localhost:6379 or rediss://...

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_IP_MAX_ATTEMPTS=15
LOGIN_IP_LOCKOUT_MINUTES=60
LOGIN_TARGET_RESPONSE_MS=300
WS_MAX_PER_IP=5
WS_MAX_PER_HOUR=100
WS_GLOBAL_MAX_SESSIONS=500

# --- WebSocket Security ----------------------------------------------------
WS_REQUIRE_EPHEMERAL_TOKEN=true
EPHEMERAL_TOKEN_EXPIRE_SECONDS=3600
SESSION_SECRET=replace_with_min_32_chars_random_secret
TOKEN_EXPIRE_SECONDS=300
WS_HEARTBEAT_INTERVAL_SEC=30
WS_PONG_TIMEOUT_SEC=10
WS_INACTIVITY_TIMEOUT_SEC=180
WS_INACTIVITY_GRACE_SEC=30
WS_MAX_SESSION_SEC=900
WS_MAX_SESSION_GRACE_SEC=30
WS_HARD_LIMIT_SEC=1200
WS_MAX_AUDIO_CHUNK_BYTES=65536
WS_MAX_MESSAGE_SIZE=262144
WS_MAX_AUDIO_SECONDS_PER_MINUTE=45
WS_MAX_CONTINUOUS_AUDIO_SEC=300

# --- Request Hardening -----------------------------------------------------
MAX_REQUEST_BYTES=10485760

# --- Cost Protection -------------------------------------------------------
DAILY_GEMINI_BUDGET_USD=50
MONTHLY_GEMINI_BUDGET_USD=500
GEMINI_EST_COST_PER_SESSION_USD=0.5

# --- Firestore Collections -------------------------------------------------
MUSEUMS_COLLECTION=museums
EXHIBITS_COLLECTION=exhibits
PERSONAS_COLLECTION=personas

# --- Seed Scripts ----------------------------------------------------------
# Optional overrides when running backend/scripts/seed_*.py
SEED_MUSEUM_ID=demo_museum
SEED_EXHIBIT_ID=statue_tran_hung_dao
# Comma-separated list, empty = seed all configured exhibits
SEED_EXHIBIT_IDS=
