# =======================================
# MuseAI Frontend — Environment Variables
# =======================================
# Copy this file to .env.local (Next.js)

# Backend base URL (HTTP)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
# Production example:
# NEXT_PUBLIC_BACKEND_URL=https://museai-backend-<project>.asia-southeast1.run.app


# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional default museum for demo/testing routes
NEXT_PUBLIC_DEFAULT_MUSEUM=demo_museum

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_DEBUG_MODE=true
